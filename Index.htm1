<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elite Web Studio</title>

<style>

/* =========================
   RESET
========================= */
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

/* =========================
   BACKGROUND
========================= */
body{
background:#000;
color:white;
overflow-x:hidden;
}

/* stars background */
.star{
position:fixed;
width:2px;
height:2px;
background:white;
border-radius:50%;
opacity:0.6;
animation:twinkle 3s infinite alternate;
}

@keyframes twinkle{
from{opacity:0.2;}
to{opacity:1;}
}

/* =========================
   NAVBAR
========================= */
nav{
position:fixed;
top:0;
width:100%;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(10px);
display:flex;
justify-content:space-between;
align-items:center;
padding:15px 30px;
z-index:1000;
}

nav h2{
color:#ffb300;
}

nav ul{
list-style:none;
display:flex;
gap:20px;
}

nav ul li{
cursor:pointer;
transition:0.3s;
}

nav ul li:hover{
color:#ff7a00;
}

/* =========================
   HERO
========================= */
.hero{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
}

.hero h1{
font-size:50px;
margin-bottom:10px;
}

.hero p{
color:#ccc;
max-width:600px;
}

.btn{
margin-top:20px;
padding:15px 30px;
border:none;
background:linear-gradient(90deg,#ff7a00,#ffb300);
color:white;
border-radius:10px;
cursor:pointer;
transition:0.3s;
}

.btn:hover{
transform:scale(1.05);
}

/* =========================
   SECTIONS
========================= */
section{
padding:80px 20px;
text-align:center;
}

h2{
margin-bottom:20px;
color:#ffb300;
}

/* cards */
.cards{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
}

.card{
background:rgba(255,255,255,0.05);
padding:20px;
border-radius:12px;
width:250px;
backdrop-filter:blur(5px);
transition:0.3s;
}

.card:hover{
transform:translateY(-5px);
background:rgba(255,255,255,0.1);
}

/* testimonials */
.testimonial{
margin:10px auto;
max-width:600px;
background:rgba(255,255,255,0.05);
padding:20px;
border-radius:10px;
}

/* contact */
input,textarea{
width:80%;
padding:10px;
margin:10px;
border:none;
border-radius:8px;
}

textarea{
height:100px;
}

/* footer */
footer{
padding:20px;
text-align:center;
color:#777;
margin-top:50px;
}

</style>

</head>

<body>

<!-- NAV -->
<nav>
<h2>Elite Studio</h2>
<ul>
<li onclick="scrollToSection('home')">Home</li>
<li onclick="scrollToSection('services')">Services</li>
<li onclick="scrollToSection('work')">Work</li>
<li onclick="scrollToSection('contact')">Contact</li>
</ul>
</nav>

<!-- HERO -->
<div class="hero" id="home">
<h1>We Build Premium Websites</h1>
<p>Modern, fast, and professional websites that help your business grow online.</p>
<button class="btn" onclick="msg()">Get Started</button>
</div>

<!-- SERVICES -->
<section id="services">
<h2>Our Services</h2>

<div class="cards">
<div class="card">Business Websites</div>
<div class="card">Landing Pages</div>
<div class="card">E-Commerce</div>
<div class="card">Portfolio Sites</div>
</div>
</section>

<!-- WORK -->
<section id="work">
<h2>Our Work</h2>

<div class="cards">
<div class="card">Restaurant Site</div>
<div class="card">Barber Shop</div>
<div class="card">Online Store</div>
</div>
</section>

<!-- TESTIMONIALS -->
<section>
<h2>Testimonials</h2>

<div class="testimonial">
"Best web service I ever used!" ⭐⭐⭐⭐⭐
</div>

<div class="testimonial">
"My business got more clients after the website." ⭐⭐⭐⭐⭐
</div>

</section>

<!-- CONTACT -->
<section id="contact">
<h2>Contact Us</h2>

<input type="text" placeholder="Your Name">
<br>
<input type="email" placeholder="Your Email">
<br>
<textarea placeholder="Message"></textarea>
<br>
<button class="btn">Send Message</button>

<br><br>

<a href="https://wa.me/212600000000">
<button class="btn">WhatsApp</button>
</a>

</section>

<!-- FOOTER -->
<footer>
© 2026 Elite Web Studio - All Rights Reserved
</footer>

<script>

/* =========================
   STARS GENERATION
========================= */
for(let i=0;i<120;i++){
let star=document.createElement("div");
star.className="star";

star.style.left=Math.random()*100+"vw";
star.style.top=Math.random()*100+"vh";

document.body.appendChild(star);
}

/* =========================
   FUNCTIONS
========================= */
function msg(){
alert("Let's build your website 🔥");
}

/* smooth scroll */
function scrollToSection(id){
document.getElementById(id).scrollIntoView({behavior:"smooth"});
}

</script>

</body>
</html>
